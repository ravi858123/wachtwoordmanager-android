<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/wit">

    <!-- Blauwe bovenbalk -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/blauw"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔑 Wachtwoordmanager"
            android:textColor="@color/wit"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnVergrendel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/vergrendelen"
            android:textColor="@color/wit"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"
            app:strokeColor="@color/wit"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <!-- Zoekbalk -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/zoeken"
        android:layout_margin="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:startIconDrawable="@android:drawable/ic_menu_search">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etZoeken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionSearch"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Items lijst -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

    <!-- Drijvende knop onderaan -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabNieuw"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/nieuw_item"
        android:textColor="@color/wit"
        app:backgroundTint="@color/blauw"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/wit"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>
