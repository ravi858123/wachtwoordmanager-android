<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/wit">

    <!-- Blauwe bovenbalk -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/blauw"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnTerug"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/wit"
            android:contentDescription="Terug"/>

        <TextView
            android:id="@+id/tvTitelBalk"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Item bewerken"
            android:textColor="@color/wit"
            android:textSize="17sp"
            android:textStyle="bold"
            android:paddingStart="8dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Naam -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNaam"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/naam"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNaam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Gebruikersnaam -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGebruikersnaam"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/gebruikersnaam"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGebruikersnaam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Wachtwoord -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilWachtwoord"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/wachtwoord"
                android:layout_marginBottom="8dp"
                app:passwordToggleEnabled="true">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWachtwoord"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Generator rij -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lengte"
                    android:textColor="@color/grijs_tekst"
                    android:textSize="13sp"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderLengte"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="8dp"
                    android:valueFrom="8"
                    android:valueTo="32"
                    android:value="16"
                    android:stepSize="1"
                    app:thumbColor="@color/blauw"
                    app:trackColorActive="@color/blauw"
                    app:trackColorInactive="@color/grijs"/>

                <TextView
                    android:id="@+id/tvLengte"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="16"
                    android:textColor="@color/donker"
                    android:textSize="13sp"/>

                <CheckBox
                    android:id="@+id/cbSymbolen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/symbolen"
                    android:textSize="13sp"
                    android:checked="true"
                    android:buttonTint="@color/blauw"
                    android:layout_marginStart="8dp"/>

                <Button
                    android:id="@+id/btnGenereer"
                    style="@style/WitKnop"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/genereer"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- URL -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUrl"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/url"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notities -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNotities"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/notities"
                android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Status tekst -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/groen"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"
                android:visibility="invisible"/>

            <!-- Knoppen -->
            <Button
                android:id="@+id/btnKopieer"
                style="@style/WitKnop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/kopieer"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnOpslaan"
                style="@style/BlauwKnop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opslaan"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnVerwijder"
                style="@style/RoodKnop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/verwijderen"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
