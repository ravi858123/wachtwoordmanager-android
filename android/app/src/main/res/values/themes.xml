<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Wachtwoordmanager" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/blauw</item>
        <item name="colorPrimaryDark">@color/blauw_donker</item>
        <item name="colorAccent">@color/blauw</item>
        <item name="android:windowBackground">@color/wit</item>
        <item name="android:textColorPrimary">@color/donker</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="BlauwKnop" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/blauw</item>
        <item name="android:textColor">@color/wit</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="RoodKnop" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/rood</item>
        <item name="android:textColor">@color/wit</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="WitKnop" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/donker</item>
        <item name="strokeColor">@color/grijs_tekst</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>
